# Database
DATABASE_URL="file:./dev.db"

# Session (至少 32 字符，生产环境请更换)
SESSION_SECRET="your-secret-key-at-least-32-characters-long"

# Kimi API (Moonshot)
KIMI_API_KEY=your_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 可选备用模型
BACKUP_1_API_KEY=
BACKUP_1_BASE_URL=https://api.siliconflow.cn/v1
BACKUP_1_MODEL=deepseek-ai/DeepSeek-V3

BACKUP_2_API_KEY=
BACKUP_2_BASE_URL=https://openrouter.ai/api/v1
BACKUP_2_MODEL=anthropic/claude-3.5-sonnet

# Optional: Cost control
MAX_TOKENS_PER_CHAPTER=8000
COST_WARNING_THRESHOLD=0.5
